# Lightweight test image — no Java/tmux needed
FROM python:3.11-slim

WORKDIR /app

# Install dependencies (no git needed for standard requirements)
RUN apt-get update && apt-get install -y --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# Install test dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir pytest pytest-asyncio

# Copy project files
COPY bot.py .
COPY cogs/ ./cogs/
COPY src/ ./src/
COPY tests/ ./tests/

# Create directories the code expects
RUN mkdir -p /app/mc-server /app/backups /app/logs /app/data

# Create a minimal .env so dotenv doesn't fail
RUN echo "BOT_TOKEN=test-token-not-real" > /app/.env && \
    echo "RCON_PASSWORD=test-rcon-pass" >> /app/.env

CMD ["python", "-m", "pytest", "tests/", "-v", "--tb=short"]
