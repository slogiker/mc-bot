# Lightweight test image
FROM python:3.11-slim

# Install curl for playit download
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Playit.gg binary directly (matching production with architecture auto-detection)
RUN ARCH=$(uname -m) && \
    case "$ARCH" in \
        x86_64)  PLAYIT_ARCH="amd64" ;; \
        aarch64) PLAYIT_ARCH="aarch64" ;; \
        armv7l)  PLAYIT_ARCH="armv7" ;; \
        *)       PLAYIT_ARCH="amd64" ;; \
    esac && \
    echo "Detected architecture: $ARCH, using Playit arch: $PLAYIT_ARCH" && \
    curl -Lo /usr/local/bin/playit "https://github.com/playit-cloud/playit-agent/releases/download/v1.0.10/playit-linux-$PLAYIT_ARCH" && \
    chmod +x /usr/local/bin/playit

WORKDIR /app

# Add non-root user (matching production)
RUN groupadd -r bot && useradd -r -g bot -d /app bot

# Install test dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir pytest pytest-asyncio

# Copy project files
COPY --chown=bot:bot bot.py .
COPY --chown=bot:bot cogs/ ./cogs/
COPY --chown=bot:bot src/ ./src/
COPY --chown=bot:bot tests/ ./tests/

# Create directories and set permissions (matching production)
RUN mkdir -p /app/mc-server /app/backups /app/logs /app/data \
    && chown -R bot:bot /app

# Create a minimal .env so dotenv doesn't fail
RUN echo "BOT_TOKEN=test-token-not-real" > /app/.env && \
    echo "RCON_PASSWORD=test-rcon-pass" >> /app/.env \
    && chown bot:bot /app/.env

# Switch to non-root user
USER bot

CMD ["python", "-m", "pytest", "tests/", "-v", "--tb=short"]
